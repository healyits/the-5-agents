\f1\b0\fs24 \cf0 \uc0\u1508 \u1493 \u1505 \u1496 \u1470 \u1496 \u1512 \u1488 \u1493 \u1502 \u1492 , \u1488 \u1493  \u1489 \u1513 \u1502 \u1492  \u1492 \u1502 \u1511 \u1510 \u1493 \u1506 \u1497  PTSD, \u1492 \u1497 \u1488  \u1514 \u1493 \u1508 \u1506 \u1492  \u1504 \u1508 \u1513 \u1497 \u1514  \u1502 \u1493 \u1512 \u1499 \u1489 \u1514  \u1513 \u1506 \u1500 \u1493 \u1500 \u1492  \u1500 \u1492 \u1493 \u1508 \u1497 \u1506  \u1500 \u1488 \u1495 \u1512  \u1495 \u1513 \u1497 \u1508 \u1492  \u1500 \u1488 \u1497 \u1512 \u1493 \u1506  \u1496 \u1512 \u1488 \u1493 \u1502 \u1496 \u1497  \u1499 \u1502 \u1493  \u1502 \u1500 \u1495 \u1502 \u1492 , \u1508 \u1497 \u1490 \u1493 \u1506 , \u1514 \u1488 \u1493 \u1504 \u1492  \u1511 \u1513 \u1492 , \u1488 \u1500 \u1497 \u1502 \u1493 \u1514 , \u1488 \u1493 \u1489 \u1491 \u1503  \u1502 \u1513 \u1502 \u1506 \u1493 \u1514 \u1497  \u1488 \u1493  \u1499 \u1500  \u1495 \u1493 \u1493 \u1497 \u1492  \u1502 \u1496 \u1500 \u1496 \u1500 \u1514  \u1488 \u1495 \u1512 \u1514 . \u1488 \u1504 \u1513 \u1497 \u1501  \u1492 \u1502 \u1514 \u1502 \u1493 \u1491 \u1491 \u1497 \u1501  \u1506 \u1501  \u1508 \u1493 \u1505 \u1496 \u1470 \u1496 \u1512 \u1488 \u1493 \u1502 \u1492  \u1495 \u1497 \u1497 \u1501  \u1508 \u1506 \u1502 \u1497 \u1501  \u1512 \u1489 \u1493 \u1514  \u1489 \u1514 \u1495 \u1493 \u1513 \u1514  \u1491 \u1512 \u1497 \u1499 \u1493 \u1514  \u1502 \u1514 \u1502 \u1513 \u1499 \u1514 , \u1508 \u1495 \u1491 , \u1495 \u1493 \u1505 \u1512  \u1513 \u1511 \u1496  \u1493 \u1511 \u1493 \u1513 \u1497  \u1500 \u1495 \u1494 \u1493 \u1512  \u1500 \u1513 \u1490 \u1512 \u1492 . \u1500 \u1506 \u1497 \u1514 \u1497 \u1501  \u1492 \u1501  \u1495 \u1493 \u1493 \u1497 \u1501  \u1508 \u1500 \u1488 \u1513 \u1489 \u1511 \u1497 \u1501 , \u1505 \u1497 \u1493 \u1496 \u1497 \u1501 , \u1495 \u1512 \u1491 \u1492 , \u1511 \u1493 \u1513 \u1497  \u1500 \u1492 \u1497 \u1493 \u1514  \u1489 \u1502 \u1511 \u1493 \u1502 \u1493 \u1514  \u1492 \u1493 \u1502 \u1497  \u1488 \u1491 \u1501 , \u1511 \u1493 \u1513 \u1497  \u1500 \u1497 \u1513 \u1493 \u1503 , \u1492 \u1497 \u1502 \u1504 \u1506 \u1493 \u1514  \u1502 \u1502 \u1510 \u1489 \u1497 \u1501  \u1502 \u1505 \u1493 \u1497 \u1502 \u1497 \u1501  \u1493 \u1514 \u1495 \u1493 \u1513 \u1514  \u1489 \u1491 \u1497 \u1491 \u1493 \u1514  \u1488 \u1493  \u1504 \u1497 \u1514 \u1493 \u1511  \u1502 \u1492 \u1505 \u1489 \u1497 \u1489 \u1492 . \u1489 \u1502 \u1510 \u1497 \u1488 \u1493 \u1514  \u1499 \u1494 \u1488 \u1514 , \u1499 \u1500 \u1489 \u1497  \u1513 \u1497 \u1512 \u1493 \u1514  \u1497 \u1499 \u1493 \u1500 \u1497 \u1501  \u1500 \u1502 \u1500 \u1488  \u1514 \u1508 \u1511 \u1497 \u1491  \u1502 \u1513 \u1502 \u1506 \u1493 \u1514 \u1497  \u1502 \u1488 \u1493 \u1491  \u1489 \u1514 \u1492 \u1500 \u1497 \u1498  \u1492 \u1492 \u1514 \u1502 \u1493 \u1491 \u1491 \u1493 \u1514 , \u1492 \u1514 \u1502 \u1497 \u1499 \u1492  \u1493 \u1492 \u1513 \u1497 \u1511 \u1493 \u1501 .\
\uc0\u1499 \u1500 \u1489  \u1513 \u1497 \u1512 \u1493 \u1514  \u1506 \u1489 \u1493 \u1512  \u1488 \u1491 \u1501  \u1506 \u1501  \u1508 \u1493 \u1505 \u1496 \u1470 \u1496 \u1512 \u1488 \u1493 \u1502 \u1492  \u1488 \u1497 \u1504 \u1493  \'93\u1505 \u1514 \u1501  \u1499 \u1500 \u1489  \u1502 \u1495 \u1502 \u1491 \'94, \u1488 \u1500 \u1488  \u1499 \u1500 \u1489  \u1513 \u1506 \u1493 \u1489 \u1512  \u1492 \u1499 \u1513 \u1512 \u1492  \u1497 \u1497 \u1506 \u1493 \u1491 \u1497 \u1514  \u1499 \u1491 \u1497  \u1500 \u1505 \u1497 \u1497 \u1506  \u1500 \u1489 \u1506 \u1500 \u1497 \u1493  \u1489 \u1502 \u1510 \u1489 \u1497 \u1501  \u1504 \u1508 \u1513 \u1497 \u1497 \u1501  \u1493 \u1514 \u1508 \u1511 \u1493 \u1491 \u1497 \u1497 \u1501  \u1513 \u1493 \u1504 \u1497 \u1501 . \u1492 \u1493 \u1488  \u1500 \u1493 \u1502 \u1491  \u1500 \u1494 \u1492 \u1493 \u1514  \u1505 \u1497 \u1502 \u1504 \u1497  \u1502 \u1510 \u1493 \u1511 \u1492 , \u1500 \u1492 \u1490 \u1497 \u1489  \u1500 \u1492 \u1514 \u1511 \u1508 \u1497  \u1495 \u1512 \u1491 \u1492 , \u1500 \u1500 \u1493 \u1493 \u1514  \u1488 \u1514  \u1492 \u1488 \u1491 \u1501  \u1489 \u1502 \u1512 \u1495 \u1489 \u1497 \u1501  \u1510 \u1497 \u1489 \u1493 \u1512 \u1497 \u1497 \u1501  \u1493 \u1500 \u1505 \u1508 \u1511  \u1514 \u1495 \u1493 \u1513 \u1514  \u1489 \u1497 \u1496 \u1495 \u1493 \u1503  \u1508 \u1497 \u1494 \u1497 \u1514  \u1493 \u1512 \u1490 \u1513 \u1497 \u1514 . \u1489 \u1502 \u1511 \u1512 \u1497 \u1501  \u1512 \u1489 \u1497 \u1501 , \u1499 \u1500 \u1489  \u1492 \u1513 \u1497 \u1512 \u1493 \u1514  \u1492 \u1493 \u1508 \u1498  \u1500 \u1492 \u1497 \u1493 \u1514  \u1491 \u1502 \u1493 \u1514  \u1502 \u1497 \u1497 \u1510 \u1489 \u1514  \u1489 \u1495 \u1497 \u1497  \u1492 \u1488 \u1491 \u1501  \'96 \u1504 \u1493 \u1499 \u1495 \u1493 \u1514  \u1511 \u1489 \u1493 \u1506 \u1492 , \u1502 \u1512 \u1490 \u1497 \u1506 \u1492  \u1493 \u1500 \u1488  \u1513 \u1497 \u1508 \u1493 \u1496 \u1497 \u1514 , \u1513 \u1502 \u1505 \u1497 \u1497 \u1506 \u1514  \u1500 \u1493  \u1500 \u1492 \u1514 \u1502 \u1493 \u1491 \u1491  \u1506 \u1501  \u1492 \u1511 \u1513 \u1497 \u1497 \u1501  \u1492 \u1497 \u1493 \u1502 \u1497 \u1493 \u1502 \u1497 \u1497 \u1501  \u1513 \u1502 \u1489 \u1497 \u1488 \u1492  \u1488 \u1497 \u1514 \u1492  \u1492 \u1508 \u1493 \u1505 \u1496 \u1470 \u1496 \u1512 \u1488 \u1493 \u1502 \u1492 .\
\uc0\u1488 \u1495 \u1514  \u1492 \u1514 \u1512 \u1493 \u1502 \u1493 \u1514  \u1492 \u1502 \u1512 \u1499 \u1494 \u1497 \u1493 \u1514  \u1513 \u1500  \u1499 \u1500 \u1489  \u1513 \u1497 \u1512 \u1493 \u1514  \u1492 \u1497 \u1488  \u1492 \u1497 \u1499 \u1493 \u1500 \u1514  \u1513 \u1500 \u1493  \u1500 \u1492 \u1508 \u1495 \u1497 \u1514  \u1495 \u1512 \u1491 \u1492  \u1493 \u1500 \u1492 \u1495 \u1494 \u1497 \u1512  \u1514 \u1495 \u1493 \u1513 \u1514  \u1489 \u1497 \u1496 \u1495 \u1493 \u1503 . \u1488 \u1491 \u1501  \u1506 \u1501  \u1508 \u1493 \u1505 \u1496 \u1470 \u1496 \u1512 \u1488 \u1493 \u1502 \u1492  \u1506 \u1513 \u1493 \u1497  \u1500 \u1492 \u1512 \u1490 \u1497 \u1513  \u1502 \u1488 \u1493 \u1497 \u1501  \u1490 \u1501  \u1489 \u1502 \u1510 \u1489 \u1497 \u1501  \u1512 \u1490 \u1497 \u1500 \u1497 \u1501  \u1500 \u1495 \u1500 \u1493 \u1496 \u1497 \u1503 , \u1499 \u1502 \u1493  \u1492 \u1500 \u1497 \u1499 \u1492  \u1489 \u1512 \u1495 \u1493 \u1489 , \u1504 \u1505 \u1497 \u1506 \u1492  \u1489 \u1514 \u1495 \u1489 \u1493 \u1512 \u1492  \u1510 \u1497 \u1489 \u1493 \u1512 \u1497 \u1514  \u1488 \u1493  \u1513 \u1492 \u1497 \u1497 \u1492  \u1489 \u1502 \u1511 \u1493 \u1501  \u1505 \u1490 \u1493 \u1512  \u1506 \u1501  \u1492 \u1512 \u1489 \u1492  \u1488 \u1504 \u1513 \u1497 \u1501 . \u1499 \u1500 \u1489  \u1492 \u1513 \u1497 \u1512 \u1493 \u1514  \u1506 \u1493 \u1494 \u1512  \u1500 \u1493  \u1500 \u1492 \u1512 \u1490 \u1497 \u1513  \u1513 \u1492 \u1493 \u1488  \u1500 \u1488  \u1500 \u1489 \u1491 . \u1506 \u1510 \u1501  \u1492 \u1504 \u1493 \u1499 \u1495 \u1493 \u1514  \u1513 \u1500  \u1492 \u1499 \u1500 \u1489  \u1497 \u1499 \u1493 \u1500 \u1492  \u1500 \u1492 \u1493 \u1512 \u1497 \u1491  \u1488 \u1514  \u1512 \u1502 \u1514  \u1492 \u1502 \u1514 \u1495 , \u1500 \u1492 \u1505 \u1497 \u1495  \u1488 \u1514  \u1492 \u1491 \u1506 \u1514  \u1502 \u1502 \u1495 \u1513 \u1489 \u1493 \u1514  \u1496 \u1493 \u1512 \u1491 \u1504 \u1497 \u1493 \u1514  \u1493 \u1500 \u1492 \u1494 \u1499 \u1497 \u1512  \u1500 \u1488 \u1491 \u1501  \u1513 \u1492 \u1493 \u1488  \u1504 \u1502 \u1510 \u1488  \u1489 \u1492 \u1493 \u1493 \u1492  \u1493 \u1489 \u1502 \u1511 \u1493 \u1501  \u1489 \u1496 \u1493 \u1495 . \u1497 \u1513  \u1499 \u1500 \u1489 \u1497  \u1513 \u1497 \u1512 \u1493 \u1514  \u1513 \u1502 \u1488 \u1493 \u1502 \u1504 \u1497 \u1501  \u1488 \u1508 \u1497 \u1500 \u1493  \u1500 \u1497 \u1510 \u1493 \u1512  \u1502 \u1512 \u1495 \u1489  \u1488 \u1497 \u1513 \u1497  \u1505 \u1489 \u1497 \u1489  \u1489 \u1506 \u1500 \u1497 \u1492 \u1501 , \u1500 \u1506 \u1502 \u1493 \u1491  \u1489 \u1497 \u1504 \u1501  \u1500 \u1489 \u1497 \u1503  \u1488 \u1504 \u1513 \u1497 \u1501  \u1488 \u1495 \u1512 \u1497 \u1501  \u1488 \u1493  \u1500 \u1492 \u1493 \u1489 \u1497 \u1500  \u1488 \u1493 \u1514 \u1501  \u1492 \u1495 \u1493 \u1510 \u1492  \u1502 \u1505 \u1497 \u1496 \u1493 \u1488 \u1510 \u1497 \u1492  \u1513 \u1502 \u1506 \u1493 \u1512 \u1512 \u1514  \u1502 \u1510 \u1493 \u1511 \u1492 .\
\uc0\u1514 \u1512 \u1493 \u1502 \u1492  \u1502 \u1513 \u1502 \u1506 \u1493 \u1514 \u1497 \u1514  \u1504 \u1493 \u1505 \u1508 \u1514  \u1513 \u1500  \u1499 \u1500 \u1489 \u1497  \u1513 \u1497 \u1512 \u1493 \u1514  \u1492 \u1497 \u1488  \u1492 \u1492 \u1514 \u1502 \u1493 \u1491 \u1491 \u1493 \u1514  \u1506 \u1501  \u1492 \u1514 \u1511 \u1508 \u1497  \u1495 \u1512 \u1491 \u1492 , \u1508 \u1500 \u1488 \u1513 \u1489 \u1511 \u1497 \u1501  \u1493 \u1505 \u1497 \u1493 \u1496 \u1497 \u1501 . \u1488 \u1491 \u1501  \u1492 \u1505 \u1493 \u1489 \u1500  \u1502 \u1508 \u1493 \u1505 \u1496 \u1470 \u1496 \u1512 \u1488 \u1493 \u1502 \u1492  \u1506 \u1500 \u1493 \u1500  \u1500 \u1495 \u1493 \u1493 \u1514  \u1514 \u1490 \u1493 \u1489 \u1493 \u1514  \u1511 \u1513 \u1493 \u1514  \u1493 \u1508 \u1514 \u1488 \u1493 \u1502 \u1497 \u1493 \u1514  \'96 \u1491 \u1493 \u1508 \u1511  \u1502 \u1493 \u1488 \u1509 , \u1511 \u1493 \u1510 \u1512  \u1504 \u1513 \u1497 \u1502 \u1492 , \u1512 \u1506 \u1491 , \u1489 \u1500 \u1489 \u1493 \u1500  \u1488 \u1493  \u1514 \u1495 \u1493 \u1513 \u1492  \u1513 \u1492 \u1493 \u1488  \'93\u1495 \u1493 \u1494 \u1512 \'94 \u1500 \u1488 \u1497 \u1512 \u1493 \u1506  \u1492 \u1496 \u1512 \u1488 \u1493 \u1502 \u1496 \u1497 . \u1499 \u1500 \u1489  \u1513 \u1497 \u1512 \u1493 \u1514  \u1497 \u1499 \u1493 \u1500  \u1500 \u1494 \u1492 \u1493 \u1514  \u1505 \u1497 \u1502 \u1504 \u1497 \u1501  \u1502 \u1493 \u1511 \u1491 \u1502 \u1497 \u1501  \u1500 \u1502 \u1510 \u1493 \u1511 \u1492 , \u1500 \u1492 \u1514 \u1511 \u1512 \u1489  \u1500 \u1489 \u1506 \u1500 \u1497 \u1493 , \u1500 \u1490 \u1506 \u1514  \u1489 \u1493 , \u1500 \u1492 \u1497 \u1513 \u1506 \u1503  \u1506 \u1500 \u1497 \u1493 , \u1488 \u1493  \u1500 \u1489 \u1510 \u1506  \u1508 \u1506 \u1493 \u1500 \u1492  \u1513 \u1502 \u1495 \u1494 \u1497 \u1512 \u1492  \u1488 \u1514  \u1514 \u1513 \u1493 \u1502 \u1514  \u1492 \u1500 \u1489  \u1500 \u1499 \u1488 \u1503  \u1493 \u1500 \u1506 \u1499 \u1513 \u1497 \u1493 . \u1489 \u1500 \u1497 \u1500 \u1492 , \u1497 \u1513  \u1499 \u1500 \u1489 \u1497 \u1501  \u1513 \u1502 \u1488 \u1493 \u1502 \u1504 \u1497 \u1501  \u1500 \u1492 \u1506 \u1497 \u1512  \u1488 \u1514  \u1492 \u1488 \u1491 \u1501  \u1502 \u1505 \u1497 \u1493 \u1496 \u1497 \u1501  \u1488 \u1493  \u1500 \u1505 \u1508 \u1511  \u1514 \u1495 \u1493 \u1513 \u1514  \u1512 \u1493 \u1490 \u1506  \u1500 \u1488 \u1495 \u1512  \u1497 \u1511 \u1497 \u1510 \u1492  \u1502 \u1489 \u1493 \u1492 \u1500 \u1514 . \u1506 \u1489 \u1493 \u1512  \u1502 \u1497  \u1513 \u1505 \u1493 \u1489 \u1500  \u1502 \u1492 \u1508 \u1512 \u1506 \u1493 \u1514  \u1513 \u1497 \u1504 \u1492 , \u1492 \u1514 \u1502 \u1497 \u1499 \u1492  \u1492 \u1494 \u1488 \u1514  \u1497 \u1499 \u1493 \u1500 \u1492  \u1500 \u1492 \u1497 \u1493 \u1514  \u1489 \u1506 \u1500 \u1514  \u1506 \u1512 \u1498  \u1506 \u1510 \u1493 \u1501 .\
\uc0\u1502 \u1506 \u1489 \u1512  \u1500 \u1505 \u1497 \u1493 \u1506  \u1489 \u1512 \u1490 \u1506 \u1497  \u1502 \u1513 \u1489 \u1512 , \u1499 \u1500 \u1489 \u1497  \u1513 \u1497 \u1512 \u1493 \u1514  \u1514 \u1493 \u1512 \u1502 \u1497 \u1501  \u1490 \u1501  \u1500 \u1513 \u1490 \u1512 \u1492  \u1492 \u1497 \u1493 \u1502 \u1497 \u1493 \u1502 \u1497 \u1514  \u1493 \u1500 \u1513 \u1497 \u1511 \u1493 \u1501  \u1492 \u1514 \u1508 \u1511 \u1493 \u1491 . \u1508 \u1493 \u1505 \u1496 \u1470 \u1496 \u1512 \u1488 \u1493 \u1502 \u1492  \u1508 \u1493 \u1490 \u1506 \u1514  \u1508 \u1506 \u1502 \u1497 \u1501  \u1512 \u1489 \u1493 \u1514  \u1489 \u1497 \u1499 \u1493 \u1500 \u1514  \u1500 \u1510 \u1488 \u1514  \u1502 \u1492 \u1489 \u1497 \u1514 , \u1500 \u1506 \u1489 \u1493 \u1491 , \u1500 \u1500 \u1502 \u1493 \u1491 , \u1500 \u1504 \u1492 \u1500  \u1511 \u1513 \u1512 \u1497 \u1501  \u1495 \u1489 \u1512 \u1514 \u1497 \u1497 \u1501  \u1488 \u1493  \u1500 \u1489 \u1510 \u1506  \u1508 \u1506 \u1493 \u1500 \u1493 \u1514  \u1489 \u1505 \u1497 \u1505 \u1497 \u1493 \u1514  \u1500 \u1500 \u1488  \u1506 \u1493 \u1502 \u1505  \u1504 \u1508 \u1513 \u1497  \u1499 \u1489 \u1491 . \u1499 \u1500 \u1489  \u1513 \u1497 \u1512 \u1493 \u1514  \u1497 \u1493 \u1510 \u1512  \u1502 \u1505 \u1490 \u1512 \u1514 . \u1492 \u1493 \u1488  \u1494 \u1511 \u1493 \u1511  \u1500 \u1496 \u1497 \u1493 \u1500 \u1497 \u1501 , \u1500 \u1492 \u1488 \u1499 \u1500 \u1492 , \u1500 \u1496 \u1497 \u1508 \u1493 \u1500  \u1493 \u1500 \u1492 \u1514 \u1497 \u1497 \u1495 \u1505 \u1493 \u1514 , \u1493 \u1489 \u1499 \u1498  \u1502 \u1506 \u1493 \u1491 \u1491  \u1505 \u1491 \u1512  \u1497 \u1493 \u1501 , \u1488 \u1495 \u1512 \u1497 \u1493 \u1514  \u1493 \u1492 \u1514 \u1488 \u1512 \u1490 \u1504 \u1493 \u1514 . \u1506 \u1489 \u1493 \u1512  \u1488 \u1491 \u1501  \u1513 \u1502 \u1514 \u1502 \u1493 \u1491 \u1491  \u1506 \u1501  \u1511 \u1493 \u1513 \u1497  \u1504 \u1508 \u1513 \u1497 , \u1506 \u1510 \u1501  \u1511 \u1497 \u1493 \u1502 \u1492  \u1513 \u1500  \u1513 \u1490 \u1512 \u1492  \u1511 \u1489 \u1493 \u1506 \u1492  \u1492 \u1493 \u1488  \u1491 \u1489 \u1512  \u1495 \u1513 \u1493 \u1489  \u1502 \u1488 \u1493 \u1491 . \u1492 \u1513 \u1490 \u1512 \u1492  \u1492 \u1494 \u1488 \u1514  \u1500 \u1488  \u1508 \u1493 \u1514 \u1512 \u1514  \u1488 \u1514  \u1492 \u1508 \u1493 \u1505 \u1496 \u1470 \u1496 \u1512 \u1488 \u1493 \u1502 \u1492 , \u1488 \u1489 \u1500  \u1492 \u1497 \u1488  \u1497 \u1499 \u1493 \u1500 \u1492  \u1500 \u1506 \u1494 \u1493 \u1512  \u1500 \u1492 \u1495 \u1494 \u1497 \u1512  \u1514 \u1495 \u1493 \u1513 \u1514  \u1497 \u1510 \u1497 \u1489 \u1493 \u1514  \u1493 \u1513 \u1500 \u1497 \u1496 \u1492 .\
\uc0\u1497 \u1513  \u1490 \u1501  \u1495 \u1513 \u1497 \u1489 \u1493 \u1514  \u1506 \u1510 \u1493 \u1502 \u1492  \u1500 \u1492 \u1497 \u1489 \u1496  \u1492 \u1512 \u1490 \u1513 \u1497  \u1513 \u1500  \u1492 \u1511 \u1513 \u1512  \u1489 \u1497 \u1503  \u1492 \u1488 \u1491 \u1501  \u1500 \u1499 \u1500 \u1489 . \u1488 \u1504 \u1513 \u1497 \u1501  \u1492 \u1502 \u1514 \u1502 \u1493 \u1491 \u1491 \u1497 \u1501  \u1506 \u1501  \u1508 \u1493 \u1505 \u1496 \u1470 \u1496 \u1512 \u1488 \u1493 \u1502 \u1492  \u1495 \u1493 \u1493 \u1497 \u1501  \u1500 \u1506 \u1497 \u1514 \u1497 \u1501  \u1514 \u1495 \u1493 \u1513 \u1514  \u1512 \u1497 \u1495 \u1493 \u1511  \u1502 \u1492 \u1505 \u1489 \u1497 \u1489 \u1492 , \u1511 \u1493 \u1513 \u1497  \u1500 \u1505 \u1502 \u1493 \u1498  \u1506 \u1500  \u1488 \u1495 \u1512 \u1497 \u1501  \u1488 \u1493  \u1514 \u1495 \u1493 \u1513 \u1492  \u1513 \u1488 \u1507  \u1488 \u1495 \u1491  \u1500 \u1488  \u1489 \u1488 \u1502 \u1514  \u1502 \u1489 \u1497 \u1503  \u1502 \u1492  \u1506 \u1493 \u1489 \u1512  \u1506 \u1500 \u1497 \u1492 \u1501 . \u1499 \u1500 \u1489  \u1513 \u1497 \u1512 \u1493 \u1514  \u1502 \u1506 \u1504 \u1497 \u1511  \u1511 \u1513 \u1512  \u1488 \u1495 \u1512  \'96 \u1511 \u1513 \u1512  \u1513 \u1502 \u1489 \u1493 \u1505 \u1505  \u1506 \u1500  \u1504 \u1488 \u1502 \u1504 \u1493 \u1514 , \u1511 \u1489 \u1500 \u1492 , \u1506 \u1511 \u1489 \u1497 \u1493 \u1514  \u1493 \u1504 \u1493 \u1499 \u1495 \u1493 \u1514  \u1513 \u1511 \u1496 \u1492 . \u1492 \u1493 \u1488  \u1488 \u1497 \u1504 \u1493  \u1513 \u1493 \u1508 \u1496 , \u1488 \u1497 \u1504 \u1493  \u1513 \u1493 \u1488 \u1500  \u1513 \u1488 \u1500 \u1493 \u1514 , \u1493 \u1488 \u1497 \u1504 \u1493  \u1502 \u1510 \u1508 \u1492  \u1500 \u1492 \u1505 \u1489 \u1512 \u1497 \u1501 . \u1506 \u1489 \u1493 \u1512  \u1512 \u1489 \u1497 \u1501 , \u1492 \u1495 \u1497 \u1489 \u1493 \u1512  \u1492 \u1494 \u1492  \u1502 \u1508 \u1495 \u1497 \u1514  \u1514 \u1495 \u1493 \u1513 \u1514  \u1489 \u1491 \u1497 \u1491 \u1493 \u1514 , \u1502 \u1506 \u1504 \u1497 \u1511  \u1504 \u1495 \u1502 \u1492  \u1493 \u1502 \u1495 \u1494 \u1511  \u1488 \u1514  \u1492 \u1497 \u1499 \u1493 \u1500 \u1514  \u1500 \u1492 \u1514 \u1502 \u1493 \u1491 \u1491  \u1506 \u1501  \u1497 \u1502 \u1497 \u1501  \u1511 \u1513 \u1497 \u1501 . \u1500 \u1508 \u1506 \u1502 \u1497 \u1501 , \u1506 \u1510 \u1501  \u1492 \u1497 \u1491 \u1497 \u1506 \u1492  \u1513 \u1497 \u1513  \u1500 \u1497 \u1491 \u1498  \u1497 \u1510 \u1493 \u1512  \u1495 \u1497  \u1513 \u1514 \u1500 \u1493 \u1497  \u1489 \u1498 , \u1502 \u1500 \u1493 \u1493 \u1492  \u1488 \u1493 \u1514 \u1498  \u1493 \u1504 \u1502 \u1510 \u1488  \u1513 \u1501  \u1514 \u1502 \u1497 \u1491  \'96 \u1492 \u1497 \u1488  \u1502 \u1511 \u1493 \u1512  \u1499 \u1493 \u1495  \u1502 \u1513 \u1502 \u1506 \u1493 \u1514 \u1497  \u1502 \u1488 \u1493 \u1491 .\
\uc0\u1489 \u1504 \u1493 \u1505 \u1507 , \u1499 \u1500 \u1489 \u1497  \u1513 \u1497 \u1512 \u1493 \u1514  \u1506 \u1513 \u1493 \u1497 \u1497 \u1501  \u1500 \u1505 \u1497 \u1497 \u1506  \u1490 \u1501  \u1489 \u1492 \u1513 \u1514 \u1500 \u1489 \u1493 \u1514  \u1495 \u1489 \u1512 \u1514 \u1497 \u1514 . \u1488 \u1491 \u1501  \u1513 \u1495 \u1493 \u1493 \u1492  \u1508 \u1493 \u1505 \u1496 \u1470 \u1496 \u1512 \u1488 \u1493 \u1502 \u1492  \u1504 \u1493 \u1496 \u1492  \u1500 \u1506 \u1497 \u1514 \u1497 \u1501  \u1500 \u1492 \u1497 \u1502 \u1504 \u1506  \u1502 \u1502 \u1508 \u1490 \u1513 \u1497 \u1501 , \u1497 \u1510 \u1497 \u1488 \u1493 \u1514  \u1488 \u1493  \u1502 \u1511 \u1493 \u1502 \u1493 \u1514  \u1495 \u1491 \u1513 \u1497 \u1501  \u1489 \u1490 \u1500 \u1500  \u1508 \u1495 \u1491 , \u1489 \u1493 \u1513 \u1492  \u1488 \u1493  \u1511 \u1493 \u1513 \u1497  \u1504 \u1508 \u1513 \u1497 . \u1499 \u1500 \u1489  \u1492 \u1513 \u1497 \u1512 \u1493 \u1514  \u1497 \u1499 \u1493 \u1500  \u1500 \u1513 \u1502 \u1513  \u1499 \u1490 \u1513 \u1512  \u1500 \u1506 \u1493 \u1500 \u1501  \u1492 \u1495 \u1497 \u1510 \u1493 \u1503 . \u1492 \u1493 \u1488  \u1502 \u1488 \u1508 \u1513 \u1512  \u1497 \u1510 \u1497 \u1488 \u1492  \u1489 \u1496 \u1493 \u1495 \u1492  \u1497 \u1493 \u1514 \u1512  \u1502 \u1492 \u1489 \u1497 \u1514 , \u1502 \u1508 \u1495 \u1497 \u1514  \u1488 \u1514  \u1514 \u1495 \u1493 \u1513 \u1514  \u1492 \u1488 \u1497 \u1493 \u1501  \u1489 \u1502 \u1512 \u1495 \u1489  \u1492 \u1510 \u1497 \u1489 \u1493 \u1512 \u1497  \u1493 \u1500 \u1506 \u1497 \u1514 \u1497 \u1501  \u1490 \u1501  \u1502 \u1511 \u1500  \u1506 \u1500  \u1497 \u1510 \u1497 \u1512 \u1514  \u1488 \u1497 \u1504 \u1496 \u1512 \u1488 \u1511 \u1510 \u1497 \u1493 \u1514  \u1506 \u1501  \u1488 \u1495 \u1512 \u1497 \u1501 . \u1489 \u1502 \u1493 \u1489 \u1503  \u1492 \u1494 \u1492 , \u1499 \u1500 \u1489  \u1492 \u1513 \u1497 \u1512 \u1493 \u1514  \u1488 \u1497 \u1504 \u1493  \u1512 \u1511  \u1514 \u1502 \u1497 \u1499 \u1492  \u1488 \u1497 \u1513 \u1497 \u1514 , \u1488 \u1500 \u1488  \u1490 \u1501  \u1499 \u1500 \u1497  \u1513 \u1502 \u1505 \u1497 \u1497 \u1506  \u1500 \u1488 \u1491 \u1501  \u1500 \u1495 \u1494 \u1493 \u1512  \u1489 \u1492 \u1491 \u1512 \u1490 \u1492  \u1500 \u1495 \u1497 \u1497 \u1501  \u1508 \u1506 \u1497 \u1500 \u1497 \u1501  \u1497 \u1493 \u1514 \u1512 .\
\uc0\u1495 \u1513 \u1493 \u1489  \u1500 \u1492 \u1491 \u1490 \u1497 \u1513  \u1513 \u1499 \u1500 \u1489  \u1513 \u1497 \u1512 \u1493 \u1514  \u1488 \u1497 \u1504 \u1493  \u1502 \u1495 \u1500 \u1497 \u1507  \u1496 \u1497 \u1508 \u1493 \u1500  \u1504 \u1508 \u1513 \u1497 , \u1514 \u1502 \u1497 \u1499 \u1492  \u1502 \u1511 \u1510 \u1493 \u1506 \u1497 \u1514  \u1488 \u1493  \u1514 \u1492 \u1500 \u1497 \u1498  \u1513 \u1497 \u1511 \u1493 \u1502 \u1497 . \u1492 \u1493 \u1488  \u1488 \u1497 \u1504 \u1493  \'93\u1502 \u1512 \u1508 \u1488 \'94 \u1508 \u1493 \u1505 \u1496 \u1470 \u1496 \u1512 \u1488 \u1493 \u1502 \u1492 , \u1493 \u1488 \u1497 \u1504 \u1493  \u1502 \u1489 \u1496 \u1500  \u1488 \u1514  \u1492 \u1511 \u1493 \u1513 \u1497 . \u1506 \u1501  \u1494 \u1488 \u1514 , \u1492 \u1493 \u1488  \u1497 \u1499 \u1493 \u1500  \u1500 \u1492 \u1497 \u1493 \u1514  \u1495 \u1500 \u1511  \u1502 \u1513 \u1502 \u1506 \u1493 \u1514 \u1497  \u1502 \u1488 \u1493 \u1491  \u1502 \u1502 \u1506 \u1512 \u1498  \u1492 \u1514 \u1502 \u1497 \u1499 \u1492  \u1513 \u1500  \u1492 \u1488 \u1491 \u1501 . \u1506 \u1489 \u1493 \u1512  \u1512 \u1489 \u1497 \u1501 , \u1492 \u1493 \u1488  \u1502 \u1513 \u1508 \u1512  \u1488 \u1514  \u1488 \u1497 \u1499 \u1493 \u1514  \u1492 \u1495 \u1497 \u1497 \u1501 , \u1502 \u1508 \u1495 \u1497 \u1514  \u1488 \u1514  \u1506 \u1493 \u1510 \u1502 \u1514  \u1492 \u1505 \u1497 \u1502 \u1508 \u1496 \u1493 \u1502 \u1497 \u1501 , \u1502 \u1495 \u1494 \u1511  \u1514 \u1495 \u1493 \u1513 \u1514  \u1502 \u1505 \u1493 \u1490 \u1500 \u1493 \u1514  \u1493 \u1502 \u1488 \u1508 \u1513 \u1512  \u1514 \u1508 \u1511 \u1493 \u1491  \u1496 \u1493 \u1489  \u1497 \u1493 \u1514 \u1512  \u1489 \u1497 \u1493 \u1501 \u1470 \u1497 \u1493 \u1501 . \u1489 \u1502 \u1511 \u1512 \u1497 \u1501  \u1502 \u1505 \u1493 \u1497 \u1502 \u1497 \u1501 , \u1492 \u1492 \u1489 \u1491 \u1500  \u1489 \u1497 \u1503  \u1495 \u1497 \u1497 \u1501  \u1513 \u1500  \u1492 \u1505 \u1514 \u1490 \u1512 \u1493 \u1514  \u1493 \u1508 \u1495 \u1491  \u1500 \u1489 \u1497 \u1503  \u1495 \u1497 \u1497 \u1501  \u1513 \u1497 \u1513  \u1489 \u1492 \u1501  \u1514 \u1504 \u1493 \u1506 \u1492 , \u1514 \u1511 \u1493 \u1493 \u1492  \u1493 \u1504 \u1513 \u1497 \u1502 \u1492  \'96 \u1506 \u1493 \u1489 \u1512  \u1491 \u1512 \u1498  \u1492 \u1514 \u1502 \u1497 \u1499 \u1492  \u1513 \u1492 \u1499 \u1500 \u1489  \u1502 \u1506 \u1504 \u1497 \u1511 .\
\uc0\u1500 \u1505 \u1497 \u1499 \u1493 \u1501 , \u1499 \u1500 \u1489 \u1497  \u1513 \u1497 \u1512 \u1493 \u1514  \u1506 \u1489 \u1493 \u1512  \u1488 \u1504 \u1513 \u1497 \u1501  \u1492 \u1502 \u1514 \u1502 \u1493 \u1491 \u1491 \u1497 \u1501  \u1506 \u1501  \u1508 \u1493 \u1505 \u1496 \u1470 \u1496 \u1512 \u1488 \u1493 \u1502 \u1492  \u1492 \u1501  \u1492 \u1512 \u1489 \u1492  \u1502 \u1506 \u1489 \u1512  \u1500 \u1506 \u1494 \u1512 \u1492  \u1496 \u1499 \u1504 \u1497 \u1514 . \u1492 \u1501  \u1502 \u1511 \u1493 \u1512  \u1500 \u1489 \u1497 \u1496 \u1495 \u1493 \u1503 , \u1497 \u1510 \u1497 \u1489 \u1493 \u1514 , \u1513 \u1490 \u1512 \u1492 , \u1512 \u1493 \u1490 \u1506  \u1493 \u1495 \u1497 \u1489 \u1493 \u1512  \u1488 \u1504 \u1493 \u1513 \u1497 \u1470 \u1512 \u1490 \u1513 \u1497  \u1502 \u1505 \u1493 \u1490  \u1488 \u1495 \u1512 . \u1489 \u1506 \u1493 \u1500 \u1501  \u1513 \u1489 \u1493  \u1492 \u1508 \u1493 \u1505 \u1496 \u1470 \u1496 \u1512 \u1488 \u1493 \u1502 \u1492  \u1506 \u1500 \u1493 \u1500 \u1492  \u1500 \u1506 \u1512 \u1506 \u1512  \u1488 \u1514  \u1514 \u1495 \u1493 \u1513 \u1514  \u1492 \u1489 \u1497 \u1496 \u1495 \u1493 \u1503  \u1492 \u1489 \u1505 \u1497 \u1505 \u1497 \u1514  \u1489 \u1497 \u1493 \u1514 \u1512 , \u1499 \u1500 \u1489  \u1513 \u1497 \u1512 \u1493 \u1514  \u1497 \u1499 \u1493 \u1500  \u1500 \u1492 \u1508 \u1493 \u1498  \u1500 \u1506 \u1493 \u1490 \u1503  \u1513 \u1500  \u1502 \u1502 \u1513 . \u1492 \u1493 \u1488  \u1500 \u1488  \u1502 \u1493 \u1495 \u1511  \u1488 \u1514  \u1492 \u1499 \u1488 \u1489 , \u1488 \u1489 \u1500  \u1492 \u1493 \u1488  \u1506 \u1493 \u1494 \u1512  \u1500 \u1513 \u1488 \u1514  \u1488 \u1493 \u1514 \u1493 . \u1492 \u1493 \u1488  \u1500 \u1488  \u1508 \u1493 \u1514 \u1512  \u1488 \u1514  \u1492 \u1496 \u1512 \u1488 \u1493 \u1502 \u1492 , \u1488 \u1489 \u1500  \u1492 \u1493 \u1488  \u1502 \u1506 \u1504 \u1497 \u1511  \u1499 \u1500 \u1497 \u1501  \u1500 \u1495 \u1497 \u1493 \u1514  \u1500 \u1510 \u1497 \u1491 \u1492  \u1489 \u1510 \u1493 \u1512 \u1492  \u1489 \u1496 \u1493 \u1495 \u1492 , \u1512 \u1490 \u1493 \u1506 \u1492  \u1493 \u1502 \u1514 \u1508 \u1511 \u1491 \u1514  \u1497 \u1493 \u1514 \u1512 . \u1500 \u1499 \u1503 , \u1492 \u1495 \u1513 \u1497 \u1489 \u1493 \u1514  \u1513 \u1500  \u1499 \u1500 \u1489 \u1497  \u1513 \u1497 \u1512 \u1493 \u1514  \u1489 \u1514 \u1495 \u1493 \u1501  \u1492 \u1508 \u1493 \u1505 \u1496 \u1470 \u1496 \u1512 \u1488 \u1493 \u1502 \u1492  \u1492 \u1497 \u1488  \u1506 \u1510 \u1493 \u1502 \u1492  \'97 \u1500 \u1488  \u1512 \u1511  \u1489 \u1512 \u1502 \u1492  \u1492 \u1502 \u1506 \u1513 \u1497 \u1514 , \u1488 \u1500 \u1488  \u1490 \u1501  \u1489 \u1512 \u1502 \u1492  \u1492 \u1488 \u1504 \u1493 \u1513 \u1497 \u1514 , \u1492 \u1512 \u1490 \u1513 \u1497 \u1514  \u1493 \u1492 \u1495 \u1489 \u1512 \u1514 \u1497 \u1514 .\
